{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": false,
    "strictNullChecks": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "bin/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "eslint.config.js",
    "prettier.config.mjs"
  ],
  "exclude": ["dist", "node_modules", "data", ".tmp"]
}
