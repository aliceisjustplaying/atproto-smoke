{
  "name": "atproto-smoke",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "description": "ATProto PDS compatibility smoke and end-to-end browser checks",
  "type": "module",
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "clean": "rm -rf dist",
    "help": "tsx bin/atproto-smoke.ts --help",
    "list-adapters": "tsx bin/atproto-smoke.ts list-adapters",
    "lint": "eslint .",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "print-example:dual": "tsx bin/atproto-smoke.ts print-example --mode dual",
    "write:pdslab-configs": "tsx scripts/write-pdslab-configs.ts",
    "validate:example:single": "tsx bin/atproto-smoke.ts validate --mode single --config examples/bring-your-own-single.json",
    "validate:example:dual": "tsx bin/atproto-smoke.ts validate --mode dual --config examples/bring-your-own-dual.json",
    "validate:example:perlsky": "tsx bin/atproto-smoke.ts validate --mode dual --adapter perlsky --config examples/perlsky-dual.json",
    "validate:example:tranquil-pds": "tsx bin/atproto-smoke.ts validate --mode dual --adapter tranquil-pds --config examples/tranquil-pds-dual.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript/native-preview": "latest",
    "@types/node": "^24.7.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.46.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atproto-smoke": "./dist/bin/atproto-smoke.js"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliceisjustplaying/atproto-smoke.git"
  },
  "homepage": "https://github.com/aliceisjustplaying/atproto-smoke",
  "exports": {
    ".": "./dist/src/index.js",
    "./config": "./dist/src/config.js",
    "./adapters/bring-your-own": "./dist/src/adapters/bring-your-own.js",
    "./adapters/perlsky": "./dist/src/adapters/perlsky.js",
    "./adapters/tranquil-pds": "./dist/src/adapters/tranquil-pds.js",
    "./adapters/registry": "./dist/src/adapters/registry.js",
    "./lab/pdslab-targets": "./dist/src/lab/pdslab-targets.js",
    "./browser/run-single": "./dist/src/browser/run-single.js",
    "./browser/run-dual": "./dist/src/browser/run-dual.js",
    "./cli": "./dist/src/cli.js"
  }
}
